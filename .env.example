# ============================================================
# Variables de entorno requeridas para Almacén
# ============================================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env

# --- Obligatorio ---
# Clave secreta para firmar sesiones y tokens CSRF.
# Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-it

# --- Base de datos ---
# Opcional: si no se define, usa SQLite local (app/almacen.db)
# Para PostgreSQL en Render se configura automáticamente.
# DATABASE_URL=postgresql://user:password@host:5432/almacen

# --- Administrador ---
# Opcional: usuario que será considerado administrador (por defecto: cponce123.com@gmail.com)
# ADMIN_USERNAME=cponce123.com@gmail.com

# Opcional: contraseña inicial del administrador
# Si no se define, usa "Hadrones456%" solo como fallback local
# ADMIN_PASSWORD=tu-contraseña-segura-aqui

# --- Debug ---
# Opcional: activar modo debug (solo desarrollo)
# FLASK_DEBUG=1
